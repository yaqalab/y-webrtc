# Copy to .env for local dev:  cp .env.example .env
# (.env is gitignored.) Generate each secret with:  openssl rand -hex 32
#
# On the server these live in the systemd unit instead — see
# docs/y-webrtc-oracle-setup.md. ID_PEPPER and KEY_SECRET must be identical
# across all instances (Oracle primary + local fallback).

PORT=4444

# App-level secret that gates POST /register (held by the trusted client app).
SIGNALING_TOKEN=dev-app-token-change-me

# Keyed-hash pepper for user ids (plaintext ids are never stored).
ID_PEPPER=dev-id-pepper-change-me

# Signing secret for the stateless access keys.
KEY_SECRET=dev-key-secret-change-me

# CORS: browser origins allowed to call POST /register. Loopback
# (localhost/127.0.0.1/::1) is ALWAYS allowed, so local dev needs nothing here.
# In production set this to your app's exact origin(s), comma-separated — the
# matched origin is echoed back, never "*". Leave blank in dev.
# ALLOWED_ORIGINS=https://app.yourdomain.com

# Registry store: "sqlite" (default, zero deps) or "redis".
STORE=sqlite
# SQLITE_PATH=./data/registry.db
# REDIS_URL=redis://127.0.0.1:6379

# Optional identity allowlist (dormant unless true). Seed with bin/allow.js.
# REQUIRE_ALLOWLIST=false

# Optional rate-limit / key tuning (sensible defaults if unset):
# KEY_TTL=86400
# REG_LIMIT=30
# REG_WINDOW=60
# CONN_LIMIT=60
# CONN_WINDOW=60
# MSG_LIMIT=50
